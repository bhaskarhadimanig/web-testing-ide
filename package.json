{
  "name": "web-testing-ide",
  "version": "0.1.0",
  "description": "A production-ready, cross-platform desktop Web-Testing IDE that is fully local/offline",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "pnpm --filter ide-electron dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "prepare": "husky install",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "package": "pnpm --filter ide-electron package",
    "demo:recording": "node scripts/create-demo-recording.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "husky": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0"
  }
}
