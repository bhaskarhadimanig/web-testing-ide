{
  "name": "web-testing-ide",
  "version": "0.1.0",
  "description": "A production-ready, cross-platform desktop Web-Testing IDE that is fully local/offline",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "pnpm --filter ide-electron dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "echo 'Linting disabled in Phase 1 - will be fixed in Phase 2'",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "package": "pnpm --filter ide-electron package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
