{
  "name": "@web-testing-ide/runner",
  "version": "0.1.0",
  "description": "Test execution and artifact collection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "runner": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist node_modules",
    "lint": "eslint 'src/**/*.js' || true",
    "test": "jest --passWithNoTests",
    "run": "node dist/cli.js"
  },
  "dependencies": {
    "@web-testing-ide/common": "workspace:*",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
